<!-- ══════════ PAGE: КАЛЬКУЛЯТОР ══════════ -->
<main id="page-calc" class="page">
  <div class="sec-label">Быстрый ввод</div>
  <div class="card blue">
    <span class="tag blue">Tab между полями — Enter для расчёта</span>
    <div class="card-title">Вход · Стоп · Цель</div>

    <div style="margin-top:14px;" class="jform">
      <!-- быстрый ряд -->
      <div class="quick-row">
        <div>
          <label>Тикер</label>
          <input type="text" id="c-ticker" placeholder="RKLB" oninput="calcPos()" style="text-transform:uppercase">
        </div>
        <div>
          <label>Вход ($)</label>
          <input type="number" id="c-entry" placeholder="75.00" step="0.01" oninput="calcPos()" onkeydown="tabNext(event,'c-stop')">
        </div>
        <div>
          <label>Стоп ($)</label>
          <input type="number" id="c-stop" placeholder="72.50" step="0.01" oninput="calcPos()" onkeydown="tabNext(event,'c-target')">
        </div>
        <div>
          <label>Цель ($)</label>
          <input type="number" id="c-target" placeholder="80.00" step="0.01" oninput="calcPos()">
        </div>
      </div>

      <!-- дополнительные -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;margin-top:6px;">
        <div style="flex:1;min-width:140px;">
          <label>Капитал ($)</label>
          <input type="number" id="c-capital" value="104927" oninput="calcPos()">
        </div>
        <div style="flex:1;min-width:120px;">
          <label>Риск (%)</label>
          <input type="number" id="c-risk-pct" value="0.75" step="0.05" oninput="calcPos()">
        </div>
        <div style="display:flex;gap:8px;padding-bottom:2px;">
          <button class="btn sm" onclick="calcPos()">Рассчитать</button>
          <button class="calc-reset" onclick="resetCalc()">Сбросить</button>
        </div>
      </div>

      <div id="calc-result" class="calc-result"></div>
    </div>
  </div>

  <div class="sec-label">Формула</div>
  <div class="formula">
    Риск в $ = <strong>Капитал × % риска</strong><br>
    Лот = <strong>Риск $ ÷ (Вход − Стоп)</strong><br>
    Цель 2R = <strong>Вход + (Вход − Стоп) × 2</strong><br>
    Цель 3R = <strong>Вход + (Вход − Стоп) × 3</strong>
  </div>
</main>

<!-- ══════════ PAGE: ДНЕВНИК ══════════ -->
<main id="page-journal" class="page">
  <div class="sec-label">Новая запись</div>
  <div class="card green">
    <span class="tag green">5 минут после каждой сделки</span>
    <div class="jform" style="margin-top:14px;" id="journal-form">
      <input type="hidden" id="j-edit-id" value="">
      <div class="jrow">
        <div><label>Дата</label><input type="date" id="j-date"></div>
