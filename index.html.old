      <tr><td><span class="ticker-sym">NOW</span></td><td>ServiceNow</td><td>Enterprise SaaS</td><td>+$1,840 на последней сделке</td><td>$85–95</td><td><span class="tag green"><span class="signal-dot s-green"></span>Активен</span></td></tr>
