      <tr><td><span class="ticker-sym">OKLO</span></td><td>Oklo Inc</td><td>Ядерная энергия</td><td>+$617 в апреле, новостной катализатор</td><td>$60–68</td><td><span class="tag amber"><span class="signal-dot s-amber"></span>Наблюдение</span></td></tr>
      <tr><td><span class="ticker-sym">GLXY</span></td><td>Galaxy Digital</td><td>Крипто</td><td>+$533, коррелирует с BTC</td><td>$22–28</td><td><span class="tag amber"><span class="signal-dot s-amber"></span>Наблюдение</span></td></tr>
      <tr><td><span class="ticker-sym">GME</span></td><td>GameStop</td><td>Мем</td><td>+$610 — только при катализаторе</td><td>$23–27</td><td><span class="tag amber"><span class="signal-dot s-amber"></span>Только с катализатором</span></td></tr>
