      </div>
      <div class="jrow1">
        <label>Эмоции (0=холодный, 10=паника)</label>
        <div style="display:flex;align-items:center;gap:12px;">
          <input type="range" id="j-emotion" min="0" max="10" value="3" oninput="document.getElementById('emo-val').textContent=this.value" style="flex:1">
          <span style="font-family:'DM Mono',monospace;font-size:13px;color:var(--muted);min-width:50px;">Ур: <span id="emo-val">3</span>/10</span>
        </div>
      </div>
      <div class="jrow1">
        <label>Что сделал бы по-другому?</label>
        <textarea id="j-lesson" rows="2" placeholder="Вышел слишком рано..."></textarea>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn" onclick="saveEntry()" id="save-btn">Сохранить</button>
        <button class="btn secondary" id="cancel-edit-btn" onclick="cancelEdit()" style="display:none">Отмена</button>
        <button class="btn secondary" onclick="exportLog()">Экспорт CSV</button>
      </div>
    </div>
  </div>

  <div class="sec-label" style="margin-top:2rem;">Импорт CSV
    <label class="import-zone" style="margin-top:0;padding:6px 16px;font-size:11px;cursor:pointer;flex-shrink:0;">
      Загрузить CSV
      <input type="file" accept=".csv" onchange="importCSV(this)">
    </label>
  </div>

  <div id="tradeLog"></div>
  <div id="journal-summary" class="summary-bar" style="display:none;"></div>
</main>

<!-- ══════════ PAGE: ПРАВИЛА ══════════ -->
<main id="page-rules" class="page">
  <div class="sec-label">6 правил — нарушать нельзя</div>
  <div class="card red"><span class="tag red">Правило 1 — критическое</span><div class="card-title">Стоп выставляется ДО входа, не после</div><div class="card-body">Нет стопа — нет сделки. Точка.</div></div>
  <div class="card red"><span class="tag red">Правило 2 — критическое</span><div class="card-title">Никогда не усредняться в убыток</div><div class="card-body">ORCL: вошёл по $166, докупал по $148 — итог −$6,679. Это не усреднение, это удвоение ставки на проигрыш.</div></div>
  <div class="card red"><span class="tag red">Правило 3 — критическое</span><div class="card-title">Чёрный список — 60 дней без обсуждений</div><div class="card-body">ASTS: убил в январе → вернулся → убил → вернулся → убил снова. Итог: −$14,939.</div></div>
  <div class="card amber"><span class="tag amber">Правило 4</span><div class="card-title">Лот — по формуле, не по ощущению</div><div class="card-body">CRWV 21 января: 2,000 акций при $90 = $180,000 при капитале $110,000. Калькулятор — обязателен.</div></div>
  <div class="card amber"><span class="tag amber">Правило 5</span><div class="card-title">Платформа закрыта 16:30–21:00</div><div class="card-body">Середина дня — низкий объём, случайные движения, максимальный соблазн. Стопы выставлены — не смотришь.</div></div>
  <div class="card green"><span class="tag green">Правило 6</span><div class="card-title">Делай больше того, что работает</div><div class="card-body">RKLB, BE, NBIS, ZM, NOW, FLY — это твой edge. 5–6 качественных сделок в месяц лучше 30 случайных.</div></div>

  <div class="sec-label">Чеклист перед входом</div>
  <div class="card gold"><span class="tag gold">Все 6 пунктов — обязательно</span>
    <ul class="checklist" id="entry-checklist">
      <li onclick="toggleCheck(this)"><div class="cb">✓</div><span>Объём выше среднего 20-дневного минимум 1.5×</span></li>
      <li onclick="toggleCheck(this)"><div class="cb">✓</div><span>Акция выше 20 EMA на дневном графике</span></li>
      <li onclick="toggleCheck(this)"><div class="cb">✓</div><span>Чёткий уровень поддержки для стопа</span></li>
      <li onclick="toggleCheck(this)"><div class="cb">✓</div><span>Цель минимум 2× риска видна на графике</span></li>
      <li onclick="toggleCheck(this)"><div class="cb">✓</div><span>Нет отчётности в ближайшие 3 дня</span></li>
      <li onclick="toggleCheck(this)"><div class="cb">✓</div><span>Инструмент НЕ в чёрном списке</span></li>
    </ul>
    <div id="checklist-result" style="margin-top:12px;font-family:'DM Mono',monospace;font-size:13px;color:var(--muted);"></div>
  </div>

  <div class="sec-label">Цели</div>
  <div class="metrics">
    <div class="metric"><div class="metric-label">Цель 3 мес</div><div class="metric-val green">+15–25%</div></div>
    <div class="metric"><div class="metric-label">Цель 12 мес</div><div class="metric-val green">+40–60%</div></div>
    <div class="metric"><div class="metric-label">Макс. просадка</div><div class="metric-val red">−10%</div></div>
    <div class="metric"><div class="metric-label">Winrate цель</div><div class="metric-val">≥ 55%</div></div>
  </div>
  <div class="hlbox"><strong>Итог:</strong> У тебя хороший глаз на вход. Проблема — управление проигрышами. Три позиции без стопов уничтожили результат 27 прибыльных сделок.</div>
</main>

<script>
// ── TABS ──
function showPage(id, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  if (el) el.classList.add('active');
}

// ── CHECKLIST ──
function toggleCheck(li) {
  li.classList.toggle('checked');
  const all = document.querySelectorAll('#entry-checklist li').length;
  const checked = document.querySelectorAll('#entry-checklist li.checked').length;
  const el = document.getElementById('checklist-result');
  if (checked === all) {
    el.style.color = 'var(--green)'; el.textContent = '✓ Все 6 — вход разрешён';
  } else {
    el.style.color = 'var(--red)'; el.textContent = `✗ ${checked}/${all} — вход запрещён`;
  }
}
document.getElementById('checklist-result').textContent = '✗ 0/6 — вход запрещён';

// ── КАЛЬКУЛЯТОР ──
function tabNext(e, nextId) {
  if (e.key === 'Enter' || e.key === 'Tab') {
    e.preventDefault();
    document.getElementById(nextId).focus();
    calcPos();
  }
}

function calcPos() {
  const capital = parseFloat(document.getElementById('c-capital').value) || 0;
  const riskPct = parseFloat(document.getElementById('c-risk-pct').value) || 0;
  const entry   = parseFloat(document.getElementById('c-entry').value);
  const stop    = parseFloat(document.getElementById('c-stop').value);
  const target  = parseFloat(document.getElementById('c-target').value);
  const ticker  = (document.getElementById('c-ticker').value || '').toUpperCase();

  const el = document.getElementById('calc-result');
  if (!entry || !stop || entry <= stop) { el.style.display = 'none'; return; }

  const riskUsd = capital * riskPct / 100;
  const diff = entry - stop;
  const lot = Math.floor(riskUsd / diff);
  if (lot <= 0) { el.style.display = 'none'; return; }

  const rr2 = entry + diff * 2;
  const rr3 = entry + diff * 3;
  const profit2 = lot * (rr2 - entry);
  const profit3 = lot * (rr3 - entry);
  const actualRisk = lot * diff;
  const rrActual = target ? ((target - entry) / diff).toFixed(1) : null;
  const posSize = lot * entry;
  const pctOfCapital = (posSize / capital * 100).toFixed(1);

  const sizeWarn = posSize > capital * 0.5
    ? `<br><span class="warn">⚠ Позиция ${pctOfCapital}% от капитала — осторожно</span>` : '';
  const rrWarn = rrActual && rrActual < 2
    ? `<br><span class="err">✗ R:R = ${rrActual} — ниже минимума 2R</span>` : '';

  el.style.display = 'block';
  el.innerHTML = `
    ${ticker ? `<strong>${ticker}</strong> &nbsp;` : ''}<strong>@$${entry}</strong> &nbsp; Стоп $${stop}<br>
    Лот: <span class="big">${lot} акций</span> &nbsp; ($${posSize.toLocaleString('ru')})<br>
    Риск: <strong>$${actualRisk.toFixed(0)}</strong> (${riskPct}% капитала)<br>
    Цель 2R → $${rr2.toFixed(2)}: <strong>+$${profit2.toFixed(0)}</strong><br>
    Цель 3R → $${rr3.toFixed(2)}: <strong>+$${profit3.toFixed(0)}</strong>${rrActual ? `<br>Твоя цель: <strong>${rrActual}R</strong>${rrWarn}` : ''}${sizeWarn}
  `;
}

function resetCalc() {
  ['c-ticker','c-entry','c-stop','c-target'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('calc-result').style.display = 'none';
  document.getElementById('c-entry').focus();
}

// ── GOOGLE SHEETS API ──
const API = 'https://script.google.com/macros/s/AKfycbyP1USuGcg3vyrC-2Qi0hWh8iZ4ISjyWkGsn6p-I4Sfkbo8n4-Ziq5FEBnCqAs6LCXn/exec';

let trades = [];

const actionLabel = { 'open':'Открыл', 'close-win':'Закрыл ✓', 'close-loss':'Стоп ✗', 'adjust':'Стоп →' };
const actionColor = { 'open':'var(--blue)', 'close-win':'var(--green)', 'close-loss':'var(--red)', 'adjust':'var(--amber)' };

function setStatus(msg, color) {
  const el = document.getElementById('api-status');
  if (!el) return;
  el.textContent = msg;
  el.style.color = color || 'var(--muted)';
}

async function apiCall(params) {
  const url = API + '?' + new URLSearchParams(params).toString();
  const res = await fetch(url);
  return res.json();
}

async function loadTrades() {
  setStatus('Загружаю...', 'var(--amber)');
  try {
    const data = await apiCall({ action: 'read' });
    if (!data.ok) throw new Error('API error');
    trades = (data.trades || []).map(row => ({
      id:      row['ID'],
      date:    row['Дата'],
      ticker:  row['Тикер'],
      action:  row['Действие'],
      pnl:     parseFloat(row['P&L']) || 0,
      entry:   row['Вход'],
      lot:     row['Лот'],
      emotion: row['Эмоции'],
      why:     row['Что произошло'],
      lesson:  row['Урок'],
    })).filter(t => t.date && t.ticker).reverse();
    setStatus('Синхронизировано ✓', 'var(--green)');
    renderLog();
  } catch(e) {
    setStatus('Ошибка загрузки — проверь соединение', 'var(--red)');
  }
}

document.getElementById('j-date').value = new Date().toISOString().split('T')[0];

async function saveEntry() {
  const editId = document.getElementById('j-edit-id').value;
  const date   = document.getElementById('j-date').value;
  const ticker = document.getElementById('j-ticker').value.trim().toUpperCase();
  const action = document.getElementById('j-action').value;
  const pnl    = parseFloat(document.getElementById('j-pnl').value) || 0;
  const entry  = document.getElementById('j-entry').value;
  const lot    = document.getElementById('j-lot').value;
  const why    = document.getElementById('j-why').value;
  const lesson = document.getElementById('j-lesson').value;
  const emotion= document.getElementById('j-emotion').value;

  if (!ticker || !date) { alert('Укажи дату и тикер'); return; }

  const id = editId || String(Date.now());
  const trade = {
    'ID': id, 'Дата': date, 'Тикер': ticker, 'Действие': action,
    'P&L': pnl, 'Вход': entry, 'Лот': lot, 'Эмоции': emotion,
    'Что произошло': why, 'Урок': lesson
  };

  const btn = document.getElementById('save-btn');
  btn.textContent = 'Сохраняю...';
  btn.disabled = true;
  setStatus('Сохраняю...', 'var(--amber)');

  try {
    const apiAction = editId ? 'update' : 'save';
    const res = await apiCall({ action: apiAction, trade: JSON.stringify(trade) });
    if (!res.ok) throw new Error();
    setStatus('Сохранено ✓', 'var(--green)');
    if (editId) cancelEdit(); else clearForm();
    await loadTrades();
  } catch(e) {
    setStatus('Ошибка сохранения', 'var(--red)');
    alert('Не удалось сохранить. Проверь соединение.');
  } finally {
    btn.textContent = editId ? 'Сохранить изменения' : 'Сохранить';
    btn.disabled = false;
  }
}

function editEntry(id) {
  const t = trades.find(t => String(t.id) === String(id));
  if (!t) return;

  document.getElementById('j-edit-id').value = t.id;
  document.getElementById('j-date').value    = t.date;
  document.getElementById('j-ticker').value  = t.ticker;
  document.getElementById('j-action').value  = t.action;
  document.getElementById('j-pnl').value     = t.pnl || '';
  document.getElementById('j-entry').value   = t.entry || '';
  document.getElementById('j-lot').value     = t.lot || '';
  document.getElementById('j-why').value     = t.why || '';
  document.getElementById('j-lesson').value  = t.lesson || '';
  document.getElementById('j-emotion').value = t.emotion || 3;
  document.getElementById('emo-val').textContent = t.emotion || 3;

  document.getElementById('save-btn').textContent = 'Сохранить изменения';
  document.getElementById('cancel-edit-btn').style.display = '';
  document.getElementById('journal-form').scrollIntoView({ behavior:'smooth', block:'start' });
}

function cancelEdit() {
  document.getElementById('j-edit-id').value = '';
  document.getElementById('save-btn').textContent = 'Сохранить';
  document.getElementById('cancel-edit-btn').style.display = 'none';
  clearForm();
}

function clearForm() {
  document.getElementById('j-ticker').value  = '';
  document.getElementById('j-pnl').value     = '';
  document.getElementById('j-entry').value   = '';
  document.getElementById('j-lot').value     = '';
  document.getElementById('j-why').value     = '';
  document.getElementById('j-lesson').value  = '';
  document.getElementById('j-emotion').value = 3;
  document.getElementById('emo-val').textContent = '3';
  document.getElementById('j-date').value = new Date().toISOString().split('T')[0];
}

async function deleteEntry(id) {
  if (!confirm('Удалить запись?')) return;
  setStatus('Удаляю...', 'var(--amber)');
  try {
    const res = await apiCall({ action: 'delete', id: String(id) });
    if (!res.ok) throw new Error();
    setStatus('Удалено ✓', 'var(--green)');
    await loadTrades();
  } catch(e) {
    setStatus('Ошибка удаления', 'var(--red)');
  }
}

function renderLog() {
  const el = document.getElementById('tradeLog');
  const sum = document.getElementById('journal-summary');

  if (trades.length === 0) {
    el.innerHTML = '<div style="text-align:center;padding:2rem;font-size:13px;color:var(--muted)">Пока нет записей</div>';
    sum.style.display = 'none';
    return;
  }

  el.innerHTML = trades.map(t => {
    const pnlHtml = t.pnl !== 0
      ? `<span class="te-pnl ${t.pnl > 0 ? 'pos' : 'neg'}">${t.pnl > 0 ? '+' : ''}$${t.pnl}</span>` : '';
    const metaParts = [];
    if (t.entry) metaParts.push(`@$${t.entry}`);
    if (t.lot) metaParts.push(`${t.lot} шт`);
    if (t.emotion !== undefined && t.emotion !== '') metaParts.push(`эмоции: ${t.emotion}/10`);
    return `
    <div class="trade-entry" id="entry-${t.id}">
      <div class="te-header">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <span class="te-ticker">${t.ticker}</span>
          <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:rgba(255,255,255,0.06);color:${actionColor[t.action]||'var(--muted)'};">${actionLabel[t.action]||t.action}</span>
          <span style="font-size:12px;color:var(--muted);">${t.date}</span>
          ${metaParts.length ? `<span class="te-meta">${metaParts.join(' · ')}</span>` : ''}
        </div>
        <div class="te-actions">
          ${pnlHtml}
          <button class="btn sm secondary" onclick="editEntry('${t.id}')">Изменить</button>
          <button class="btn sm danger" onclick="deleteEntry('${t.id}')">✕</button>
        </div>
      </div>
      ${t.why ? `<div class="te-why">${t.why}${t.lesson ? `<br><span style="color:var(--amber)">→ ${t.lesson}</span>` : ''}</div>` : ''}
    </div>`;
  }).join('');

  const closed = trades.filter(t => t.action === 'close-win' || t.action === 'close-loss');
  const totalPnl = closed.reduce((a, t) => a + (t.pnl || 0), 0);
  const wins = closed.filter(t => (t.pnl || 0) > 0).length;
  const wr = closed.length ? Math.round(wins / closed.length * 100) : 0;

  sum.style.display = 'flex';
  sum.innerHTML = `
    <div class="sb-item"><span class="sb-val" style="color:${totalPnl>=0?'var(--green)':'var(--red)'}">${totalPnl>=0?'+':''}$${totalPnl.toFixed(0)}</span><span class="sb-label">Общий P&L</span></div>
    <div class="sb-item"><span class="sb-val">${closed.length}</span><span class="sb-label">Закрытых</span></div>
    <div class="sb-item"><span class="sb-val" style="color:${wr>=55?'var(--green)':'var(--amber)'}">${wr}%</span><span class="sb-label">Winrate</span></div>
    <div class="sb-item"><span class="sb-val" style="color:var(--green)">${wins}</span><span class="sb-label">Прибыльных</span></div>
    <div class="sb-item"><span class="sb-val" style="color:var(--red)">${closed.length - wins}</span><span class="sb-label">По стопу</span></div>
    <div class="sb-item"><span class="sb-val">${trades.length}</span><span class="sb-label">Всего записей</span></div>
  `;
}

function exportLog() {
  if (trades.length === 0) { alert('Нет записей'); return; }
  const rows = [['Дата','Тикер','Действие','P&L','Вход','Лот','Эмоции','Что произошло','Урок','ID']];
  trades.forEach(t => rows.push([t.date,t.ticker,t.action,t.pnl,t.entry,t.lot,t.emotion,t.why,t.lesson,t.id]));
  const csv = rows.map(r => r.map(c => '"'+(c||'').toString().replace(/"/g,'""')+'"').join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,\uFEFF' + encodeURIComponent(csv);
  a.download = 'trading_journal_vadim.csv';
  a.click();
}

loadTrades();
</script>
</body>
</html>
